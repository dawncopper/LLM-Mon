generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ApiKey {
  id        String   @id @default(cuid())
  provider  String   // openai, anthropic, azure, custom
  key       String   // 加密存储
  label     String
  createdAt DateTime @default(now())
  models    Model[]

  @@map("api_keys")
}

model Model {
  id           String    @id @default(cuid())
  name         String
  apiDocUrl    String?
  apiEndpoint  String
  createdAt    DateTime  @default(now())
  apiKeyId     String
  apiKey       ApiKey    @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  metrics      Metric[]

  @@index([apiKeyId])
  @@map("models")
}

model Metric {
  id           String   @id @default(cuid())
  responseTime Int      // ms
  success      Boolean
  timestamp    DateTime @default(now())
  modelId      String
  model        Model    @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@index([timestamp])
  @@map("metrics")
}
