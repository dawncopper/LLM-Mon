{
  "name": "llm-mon",
  "version": "1.0.0",
  "private": true,
  "description": "LLM service quality monitoring platform",
  "scripts": {
    "dev": "vite",
    "build": "npx tsc -b && npx vite build",
    "preview": "vite preview",
    "start": "cd backend && npm start",
    "backend:install": "cd backend && npm install",
