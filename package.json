    "backend:start": "cd backend && npm start",
    "backend:db-push": "cd backend && npx prisma db push",
    "frontend:install": "npm install",
    "frontend:build": "npx tsc -b && npx vite build"
  },
  "engines": {
    "node": ">=18"
  }
}