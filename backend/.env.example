# 数据库连接
DATABASE_URL="postgresql://user:password@localhost:5432/llm_monitor"

# 端口（可选，默认 3000）
PORT=3000

# API Key 加密密钥（生产环境请务必修改！）
ENCRYPTION_KEY="your-secret-encryption-key-change-this-in-production"

# JWT 签名密钥（生产环境请务必修改！）
JWT_SECRET="your-secret-jwt-key-change-this-in-production"

# 是否启用认证（设为 false 可关闭认证，方便本地开发）
REQUIRE_AUTH=true
