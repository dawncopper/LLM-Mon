generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  apiKeys      ApiKey[]
  models       Model[]

  @@map("users")
}

model ApiKey {
  id        String   @id @default(cuid())
  provider  String   // openai, anthropic, azure, custom
  key       String   // AES 加密存储
  label     String
  createdAt DateTime @default(now())
  userId    String?  // 关联到用户（可选，保持向后兼容）
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  models    Model[]

  @@map("api_keys")
}

model Model {
  id           String    @id @default(cuid())
  name         String
  apiDocUrl    String?
  apiEndpoint  String
  createdAt    DateTime  @default(now())
  apiKeyId     String
  apiKey       ApiKey    @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  userId       String?  // 关联到用户
  user          User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  metrics      Metric[]
  testCases    TestCase[]

  @@index([apiKeyId])
  @@index([userId])
  @@map("models")
}

model Metric {
  id                    String   @id @default(cuid())
  responseTime          Int      // ms
  success               Boolean
  juiceValue            Int?
  juiceTrend            String?  // "stable" | "degrading" | "improving" | null
  juiceBaseline         Int?     // 最近 5 次 Juice 平均值作为基准线
  successRate           Float?   // 本轮所有测试用例的成功率 0-100
  qualityScore          Float?   // 综合质量分 0-100
  consistencyScore      Float?   // 响应时间一致性分数 0-100
  throughputTPS         Float?   // 吞吐量 (words/sec)
  timestamp             DateTime @default(now())
  modelId               String
  model                 Model    @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@index([timestamp])
  @@map("metrics")
}

model TestCase {
  id        String   @id @default(cuid())
  name      String
  prompt    String
  category  String   // basic, reasoning, fingerprint, custom
  createdAt DateTime @default(now())
  modelId   String
  model     Model    @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@map("test_cases")
}
